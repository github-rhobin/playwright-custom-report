{
    "compilerOptions": {
      "target": "ES2022",
      "module": "commonjs",
      "moduleResolution": "node",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "types": ["node"]
    },
    "include": [
      "playwright.config.ts",
      "tests/**/*.ts",
      "src/reporter/**/*.ts",
      "src/utils/**/*.ts",
      "src/config/**/*.ts"
    ]
  }